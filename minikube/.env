# Central knobs for the kubecompose stack. docker compose auto-loads this file from the
# project directory (make runs compose with --project-directory minikube).
# Precedence: shell env (`CILIUM=off make minikube`) > this file > compose-file default.

# CNI toggle, consumed by apply-addons.service at boot (runtime, no rebuild).
# on  = cilium (normal cluster)
# off = kindnet fallback instead — minimal CNI so the cluster stays healthy without cilium
CILIUM=on
